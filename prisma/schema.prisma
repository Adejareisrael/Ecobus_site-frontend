generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                  String               @id @default(cuid())
  name                String
  email               String               @unique
  phone               String?
  password            String
  role                String               @default("customer")
  bookings            Booking[]
  passwordResetTokens PasswordResetToken[]
  createdAt           DateTime             @default(now())
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
}

model Booking {
  id             String   @id @default(cuid())
  reference      String   @unique
  paystackRef    String   @unique
  paymentStatus  String   @default("Paid")
  amountPaid     Int?
  currency       String   @default("NGN")
  paidAt         DateTime?
  tripId         String
  travelDate     String   @default("")
  routeLabel     String
  departureTime  String
  busType        String
  price          Int
  promoCode      String?
  discountAmount Int      @default(0)
  seatsJson      String
  passengerName  String
  passengerPhone String
  passengerEmail String
  userId         String?
  user           User?    @relation(fields: [userId], references: [id])
  status         String   @default("Confirmed")
  checkedInAt    DateTime?
  checkedInBy    String?
  changeRequests BookingChangeRequest[]
  createdAt      DateTime @default(now())
}

model BookingChangeRequest {
  id             String   @id @default(cuid())
  bookingId      String
  booking        Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  userId         String?
  requestType    String
  preferredDate  String?
  reason         String
  status         String   @default("Pending")
  adminNote      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model CharterRequest {
  id           String   @id @default(cuid())
  fullName     String
  phone        String
  email        String?
  pickup       String
  destination  String
  travelDate   String
  returnDate   String?
  passengers   Int
  vehicleType  String?
  notes        String?
  status       String   @default("New")
  adminNote    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TicketDelivery {
  id          String    @id @default(cuid())
  bookingId   String
  reference   String
  channel     String
  recipient   String
  subject     String?
  message     String
  status      String    @default("Pending")
  lastError   String?
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model PromoCode {
  id            String   @id @default(cuid())
  code          String   @unique
  description   String?
  discountType  String
  discountValue Int
  minSpend      Int      @default(0)
  maxUses       Int?
  usedCount     Int      @default(0)
  startsAt      DateTime?
  expiresAt     DateTime?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Trip {
  id                    String    @id @default(cuid())

  departureTerminalId   String
  destinationTerminalId String

  routeLabel            String

  departureTime         String
  arrivalTime           String

  price                 Int
  availableSeats        Int

  busType               String
  busLayoutId           String?
  busLayout             BusLayout? @relation(fields: [busLayoutId], references: [id])
  amenitiesJson         String    @default("[]")
  isActive              Boolean  @default(true)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model BusLayout {
  id          String   @id @default(cuid())
  name        String
  model       String
  totalSeats  Int
  seatsJson   String
  isDefault   Boolean  @default(false)
  trips       Trip[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Terminal {
  id      String @id @default(cuid())

  name    String
  city    String
  state   String
  address String @default("")
  phone   String @default("")
  hours   String @default("")
  mapUrl  String @default("")
  facilitiesJson String @default("[]")

  createdAt DateTime @default(now())
}

model SiteSettings {
  id                  String   @id @default("site")
  heroTitlePrefix     String
  heroBrand           String
  heroDescription     String
  heroEyebrow         String
  heroCardTitle       String
  heroCardDescription String
  popularRoutesJson   String
  popularRouteImagesJson String @default("[]")
  footerDescription   String
  supportText         String
  whatsappNumber      String
  whatsappMessage     String
  email               String   @default("info@ecobustransport.com")
  facebookHandle      String   @default("@Ecobus.ng")
  instagramHandle     String   @default("Ecobus_transport")
  xHandle             String   @default("Ecobustransport")
  facebookUrl         String   @default("https://facebook.com/Ecobus.ng")
  instagramUrl        String   @default("https://instagram.com/Ecobus_transport")
  xUrl                String   @default("https://x.com/Ecobustransport")
  responseTimeText    String
  bottomNote          String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
